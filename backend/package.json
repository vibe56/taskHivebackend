{
  "name": "taskmanager-backend",
  "version": "1.0.0",
  "description": "Task Manager REST API — Node.js + Express + JWT Auth",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
